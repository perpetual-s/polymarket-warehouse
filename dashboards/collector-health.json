        "overrides": []
      },
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 23},
      "id": 9,
      "options": {
        "footer": {"show": false},
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  'leaderboard' AS ingestor,\n  (SELECT COUNT(*) FROM bonus.raw_wallet_leaderboard_snapshots) AS raw_rows,\n  (SELECT MAX(captured_at) FROM bonus.raw_wallet_leaderboard_snapshots) AS last_capture,\n  (SELECT COUNT(DISTINCT proxy_wallet) FROM bonus.raw_wallet_leaderboard_snapshots) AS distinct_wallets\nUNION ALL SELECT\n  'profile',\n  (SELECT COUNT(*) FROM bonus.raw_wallet_profiles),\n  (SELECT MAX(captured_at) FROM bonus.raw_wallet_profiles),\n  (SELECT COUNT(DISTINCT proxy_wallet) FROM bonus.raw_wallet_profiles)\nUNION ALL SELECT\n  'positions',\n  (SELECT COUNT(*) FROM bonus.raw_wallet_positions_snapshots),\n  (SELECT MAX(captured_at) FROM bonus.raw_wallet_positions_snapshots),\n  (SELECT COUNT(DISTINCT proxy_wallet) FROM bonus.raw_wallet_positions_snapshots)\nUNION ALL SELECT\n  'activity',\n  (SELECT COUNT(*) FROM bonus.raw_wallet_activity_events),\n  (SELECT MAX(event_ts) FROM bonus.raw_wallet_activity_events),\n  (SELECT COUNT(DISTINCT proxy_wallet) FROM bonus.raw_wallet_activity_events)\nORDER BY ingestor;",
          "refId": "A"
        }
      ],
      "title": "Raw Table Snapshot",
      "type": "table",
      "description": "Row counts, most recent capture timestamp, and distinct wallets covered per raw table."
