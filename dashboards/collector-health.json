        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ingestor, SUM(rows_inserted)::double precision AS rows_inserted\nFROM bonus.collector_runs\nWHERE status IN ('ok', 'partial')\nGROUP BY ingestor\nORDER BY rows_inserted DESC;",
          "refId": "A"
        }
      ],
      "title": "Total Rows Inserted by Ingestor",
