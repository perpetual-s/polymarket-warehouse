      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  started_at AS \"started\",\n  ingestor,\n  status,\n  rows_fetched,\n  rows_inserted,\n  rows_skipped,\n  wallet_count,\n  EXTRACT(EPOCH FROM (finished_at - started_at))::NUMERIC(10, 2) AS duration_sec,\n  COALESCE(error_message, '') AS error\nFROM bonus.collector_runs\nORDER BY started_at DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "title": "Recent Collector Runs",
      "type": "table"
    },
