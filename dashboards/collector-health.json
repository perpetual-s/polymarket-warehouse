    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "status"},
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "ok": {"color": "green", "index": 0},
                      "error": {"color": "red", "index": 1},
                      "partial": {"color": "orange", "index": 2},
                      "running": {"color": "blue", "index": 3}
                    }
                  }
                ]
              }
            ]
          }
        ]
