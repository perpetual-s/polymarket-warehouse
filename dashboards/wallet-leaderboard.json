      "id": 4,
      "options": {
        "colorMode": "value", "graphMode": "none", "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [{
        "format": "table", "rawQuery": true,
        "rawSql": "SELECT COUNT(DISTINCT market_condition_id)::double precision AS value FROM bonus.raw_market_holders_snapshots;",
        "refId": "A"
      }],
      "title": "Markets Scanned",
