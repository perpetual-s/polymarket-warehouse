      "targets": [{"format": "table", "rawQuery": true, "rawSql": "SELECT\n  COALESCE(NULLIF(w.name, ''), NULLIF(w.user_name, ''), LEFT(w.address, 12) || '...') AS wallet,\n  p.overall_gain::double precision AS pnl,\n  p.win_rate::double precision AS win_rate,\n  p.total_positions AS positions,\n  p.active_positions AS active,\n  (p.win_amount + p.loss_amount)::double precision AS volume,\n  p.total_current_value::double precision AS portfolio,\n  p.trader_tags AS tags,\n  w.address\nFROM bonus.raw_pma_trader_snapshots p\nJOIN bonus.wallets w ON w.address = p.trader_address\nWHERE p.captured_at = (SELECT MAX(captured_at) FROM bonus.raw_pma_trader_snapshots)\n  AND w.is_tracked\nORDER BY p.overall_gain DESC\nLIMIT 50;", "refId": "A"}],
