        "datasource": {"type": "postgres", "uid": "timescaledb"},
        "query": "SELECT t.condition_id AS __value, COALESCE(LEFT(MAX(m.question), 80), LEFT(MAX(t.title), 80), LEFT(t.condition_id, 20) || '...') AS __text FROM bonus.wallet_trade_events t LEFT JOIN bonus.markets m ON m.market_id = t.condition_id WHERE t.condition_id IS NOT NULL GROUP BY t.condition_id ORDER BY COUNT(*) DESC LIMIT 30;",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
