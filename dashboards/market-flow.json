      "id": 2,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"format": "table", "rawQuery": true, "rawSql": "WITH latest AS (SELECT MAX(captured_at) AS ts FROM bonus.raw_market_holders_snapshots WHERE market_condition_id = '$market')\nSELECT COUNT(DISTINCT proxy_wallet)::double precision AS value FROM bonus.raw_market_holders_snapshots h, latest WHERE h.market_condition_id = '$market' AND h.captured_at = latest.ts AND h.amount > 0;", "refId": "A"}],
      "title": "Holders",
      "type": "stat"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"format": "table", "rawQuery": true, "rawSql": "SELECT COUNT(*)::double precision AS value FROM bonus.wallet_trade_events WHERE condition_id = '$market';", "refId": "A"}],
      "title": "Tracked Trades",
      "type": "stat"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "currencyUSD", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"format": "table", "rawQuery": true, "rawSql": "SELECT (COALESCE(SUM(notional_usd) FILTER (WHERE side='BUY'), 0) - COALESCE(SUM(notional_usd) FILTER (WHERE side='SELL'), 0))::double precision AS value FROM bonus.wallet_trade_events WHERE condition_id = '$market';", "refId": "A"}],
      "title": "Tracked Net Flow",
      "type": "stat"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "bars", "fillOpacity": 60, "stacking": {"mode": "normal"}}, "unit": "currencyUSD"}, "overrides": [
        {"matcher": {"id": "byName", "options": "SELL"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
        {"matcher": {"id": "byName", "options": "BUY"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
      ]},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"format": "time_series", "rawQuery": true, "rawSql": "SELECT\n  DATE_TRUNC('hour', event_ts) AS \"time\",\n  side AS metric,\n  SUM(notional_usd)::double precision AS value\nFROM bonus.wallet_trade_events\nWHERE condition_id = '$market'\nGROUP BY 1, 2\nORDER BY 1;", "refId": "A"}],
      "title": "Tracked Hourly Buy/Sell Volume",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"drawStyle": "line", "lineWidth": 2, "pointSize": 5, "showPoints": "auto"}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"format": "time_series", "rawQuery": true, "rawSql": "SELECT\n  DATE_TRUNC('hour', event_ts) AS \"time\",\n  'wallets' AS metric,\n  COUNT(DISTINCT proxy_wallet)::double precision AS value\nFROM bonus.wallet_trade_events\nWHERE condition_id = '$market'\nGROUP BY 1\nORDER BY 1;", "refId": "A"}],
      "title": "Tracked Wallets per Hour",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": [
        {"matcher": {"id": "byName", "options": "volume"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 0}]},
        {"matcher": {"id": "byName", "options": "avg_price"}, "properties": [{"id": "decimals", "value": 3}]}
      ]},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 13},
      "id": 7,
      "options": {"footer": {"show": false}, "showHeader": true},
      "targets": [{"format": "table", "rawQuery": true, "rawSql": "SELECT\n  COALESCE(NULLIF(w.name, ''), NULLIF(w.user_name, ''), LEFT(t.proxy_wallet, 12) || '...') AS trader,\n  COUNT(*) AS trades,\n  SUM(t.notional_usd)::double precision AS volume,\n  COUNT(*) FILTER (WHERE t.side = 'BUY') AS buys,\n  COUNT(*) FILTER (WHERE t.side = 'SELL') AS sells,\n  AVG(t.price)::double precision AS avg_price,\n  t.proxy_wallet AS address\nFROM bonus.wallet_trade_events t\nLEFT JOIN bonus.wallets w ON w.address = t.proxy_wallet\nWHERE t.condition_id = '$market'\nGROUP BY t.proxy_wallet, w.name, w.user_name\nORDER BY SUM(t.notional_usd) DESC\nLIMIT 20;", "refId": "A"}],
      "title": "Top Tracked Traders in Market",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "displayMode": "auto"}}, "overrides": [
        {"matcher": {"id": "byName", "options": "notional"}, "properties": [{"id": "unit", "value": "currencyUSD"}, {"id": "decimals", "value": 0}]}
      ]},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 13},
      "id": 8,
      "options": {"footer": {"show": false}, "showHeader": true},
      "targets": [{"format": "table", "rawQuery": true, "rawSql": "SELECT\n  event_ts::timestamp(0) AS time,\n  COALESCE(NULLIF(w.name, ''), NULLIF(w.user_name, ''), LEFT(t.proxy_wallet, 12) || '...') AS trader,\n  t.side,\n  t.outcome,\n  t.price::NUMERIC(6, 4) AS price,\n  t.size::NUMERIC(14, 2) AS shares,\n  t.notional_usd::double precision AS notional\nFROM bonus.wallet_trade_events t\nLEFT JOIN bonus.wallets w ON w.address = t.proxy_wallet\nWHERE t.condition_id = '$market'\nORDER BY t.event_ts DESC\nLIMIT 50;", "refId": "A"}],
      "title": "Recent Tracked Trades",
      "type": "table"
    }
  ],
