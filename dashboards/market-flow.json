      "targets": [{"format": "table", "rawQuery": true, "rawSql": "SELECT COUNT(DISTINCT proxy_wallet)::double precision AS value FROM bonus.wallet_trade_events WHERE condition_id = '$market';", "refId": "A"}],
      "title": "Tracked Traders",
      "type": "stat"
