          "rawSql": "SELECT question,\n       category,\n       leading_outcome,\n       leading_price::double precision AS leading_price,\n       generated_volume_24h_usd::double precision AS generated_volume_24h_usd,\n       price_change_24h_pct::double precision AS price_change_24h_pct,\n       is_tracked,\n       COALESCE(group_item_title, TO_CHAR(end_date, 'YYYY-MM-DD')) AS resolution_label\nFROM bonus.v_market_overview\nORDER BY generated_volume_24h_usd DESC, leading_price DESC\nLIMIT 25;",
